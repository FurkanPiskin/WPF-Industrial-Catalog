<Window x:Class="FerraFilterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FerraFilterApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="900" Background="White">

    <Window.Resources>
        <local:ImagePathConverter x:Key="ImgConverter"/>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#CC0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="BorderBrush" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid x:Name="pnlAramaEkrani" Margin="20" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">

                <StackPanel HorizontalAlignment="Left">
                    <Border Background="#CC0000" Padding="5" Width="300" HorizontalAlignment="Left">
                        <TextBlock Text="Arama" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBox x:Name="txtSearchBox" Width="300" Height="35" FontSize="16" Padding="5,0,0,0" VerticalContentAlignment="Center" BorderBrush="#CCC"/>
                        <Button x:Name="btnSearch" Content="🔍 Ara" Width="100" Height="35" Margin="10,0,0,0" Background="#333" Foreground="White" FontWeight="Bold" Click="btnSearch_Click" Cursor="Hand" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="Parça Numarası Ekle  +" HorizontalAlignment="Left" Width="300" Background="#CC0000" Foreground="White" FontWeight="Bold" FontSize="16" Padding="10" Margin="0,20,0,0" BorderThickness="0" Cursor="Hand"/>

            </StackPanel>

            <DataGrid x:Name="dgResults" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" RowHeight="55" FontSize="14" AlternatingRowBackground="#FFF5F5F5" BorderBrush="#DDD" HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>

                    <DataGridTextColumn Header="ORİJİNAL NO" Binding="{Binding OrijinalNo}" Width="1.5*"/>
                    <DataGridTextColumn Header="ÜRETİCİ" Binding="{Binding Uretici}" Width="2*"/>

                    <DataGridTemplateColumn Header="FERRA NO" Width="1.5*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding FerraNo}" 
                                        Click="FerraNo_Click"
                                        Cursor="Hand" 
                                        Background="Transparent" 
                                        BorderThickness="0" 
                                        Foreground="#CC0000"
                                        FontWeight="Bold"
                                        HorizontalAlignment="Left">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}" VerticalAlignment="Center"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="FİLTRE DURUMU" Binding="{Binding Durum}" Width="1.5*"/>

                    <DataGridTemplateColumn Header="RESİM" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Fotograf, Converter={StaticResource ImgConverter}}" 
                                       Width="45" Height="45" Stretch="Uniform" Margin="2"
                                       ToolTip="{Binding Fotograf}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="KARŞILAŞTIR" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox HorizontalAlignment="Center" VerticalAlignment="Center" Cursor="Hand">
                                    <CheckBox.LayoutTransform>
                                        <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                                    </CheckBox.LayoutTransform>
                                </CheckBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

        </Grid>

        <Frame x:Name="frmAnaCerceve" Visibility="Collapsed" NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>